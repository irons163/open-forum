---
import { categorySummaries } from '../lib/projects';
import { baseUrl, discussionsUrl, siteRepoUrl } from '../lib/site';

const {
  title = 'Open Forum',
  description = '推薦專案、追蹤熱度、用 GitHub Discussions 討論的 GitHub Pages 骨架。',
  current = 'home',
} = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;

const navItems = [
  { key: 'home', label: '首頁', href: `${baseUrl}` },
  { key: 'rankings', label: '熱度榜', href: `${baseUrl}rankings/` },
  { key: 'community', label: '社群', href: `${baseUrl}community/` },
];

const quickLinks = [
  { label: '項目推薦', href: `${baseUrl}#discover-projects` },
  { label: '趨勢榜', href: `${baseUrl}rankings/` },
  ...categorySummaries.slice(0, 4).map((summary) => ({
    label: summary.name,
    href: `${baseUrl}?category=${encodeURIComponent(summary.name)}#discover-projects`,
  })),
  { label: '社群', href: `${baseUrl}community/` },
];
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#f57f17" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-backdrop"></div>
    <header class="site-header">
      <div class="shell header-shell">
        <a class="brand-mark" href={baseUrl}>
          <span class="brand-icon">◎</span>
          <span>
            <strong>Open Forum</strong>
            <small>GitHub Pages Project Radar</small>
          </span>
        </a>

        <form class="header-search" action={baseUrl} method="get">
          <input
            class="header-search-input"
            type="search"
            name="q"
            placeholder="搜尋感興趣的開源倉庫、主題或分類"
          />
          <input type="hidden" name="jump" value="discover-projects" />
        </form>

        <div class="header-links">
          {discussionsUrl && (
            <a class="button ghost compact" href={discussionsUrl} target="_blank" rel="noreferrer">
              Discussions
            </a>
          )}
          {siteRepoUrl && (
            <a class="button compact" href={siteRepoUrl} target="_blank" rel="noreferrer">
              Repo
            </a>
          )}
        </div>
      </div>

      <div class="shell header-subnav">
        <nav class="header-nav" aria-label="主導覽">
          {navItems.map((item) => (
            <a class:list={['nav-link', current === item.key && 'is-active']} href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="quick-links" aria-label="快速入口">
          {quickLinks.map((item) => (
            <a class="quick-link" href={item.href}>{item.label}</a>
          ))}
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell footer-shell">
        <div>
          <strong>Open Forum</strong>
          <p>用 GitHub Pages、GitHub Actions、GitHub Discussions 組出可維護的開源雷達站。</p>
        </div>
        <div class="footer-links">
          <a href={`${baseUrl}rankings/`}>熱度榜</a>
          <a href={`${baseUrl}community/`}>社群流程</a>
          {siteRepoUrl && <a href={siteRepoUrl}>原始碼</a>}
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fff9f1;
    --bg-soft: #fff2da;
    --panel: rgba(255, 255, 255, 0.82);
    --panel-strong: rgba(255, 255, 255, 0.94);
    --line: rgba(52, 37, 17, 0.12);
    --text: #24180b;
    --text-soft: #6f6252;
    --accent: #ef6c00;
    --accent-strong: #c25500;
    --accent-mint: #0f9d8a;
    --shadow: 0 28px 90px rgba(78, 43, 8, 0.12);
    --radius-xl: 28px;
    --radius-lg: 20px;
    --radius-md: 14px;
    --max-width: 1160px;
    --font-display: 'Space Grotesk', 'Noto Sans TC', sans-serif;
    --font-body: 'Noto Sans TC', sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(245, 127, 23, 0.22), transparent 35%),
      radial-gradient(circle at top right, rgba(15, 157, 138, 0.18), transparent 30%),
      linear-gradient(180deg, #fffaf4 0%, #fff3e1 40%, #f6efe5 100%);
    font-family: var(--font-body);
  }

  .page-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(36, 24, 11, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(36, 24, 11, 0.03) 1px, transparent 1px);
    background-size: 30px 30px;
    mask-image: linear-gradient(180deg, black, transparent 85%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  main {
    position: relative;
    z-index: 1;
    padding: 2rem 0 4rem;
  }

  .shell {
    width: min(calc(100% - 2rem), var(--max-width));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    background: rgba(255, 249, 241, 0.72);
    border-bottom: 1px solid rgba(52, 37, 17, 0.08);
  }

  .header-shell,
  .footer-shell {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1rem 0;
  }

  .header-subnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0 0.8rem;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
  }

  .brand-mark strong,
  h1,
  h2,
  h3 {
    font-family: var(--font-display);
    letter-spacing: -0.03em;
  }

  .brand-mark small {
    display: block;
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .brand-icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ffbd73, #ef6c00);
    color: #fff;
    box-shadow: 0 12px 30px rgba(239, 108, 0, 0.3);
  }

  .header-nav,
  .header-links,
  .action-row,
  .tag-row,
  .chip-row,
  .filter-pills,
  .quick-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .header-search {
    flex: 1;
    max-width: 34rem;
  }

  .header-search-input {
    width: 100%;
    min-height: 2.85rem;
    padding: 0.8rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(52, 37, 17, 0.12);
    background: rgba(255, 255, 255, 0.84);
    font: inherit;
    color: var(--text);
  }

  .nav-link,
  .pill,
  .tag,
  .chip {
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.55);
    padding: 0.45rem 0.85rem;
    font-size: 0.92rem;
  }

  .nav-link.is-active {
    background: linear-gradient(135deg, rgba(245, 127, 23, 0.18), rgba(15, 157, 138, 0.14));
    border-color: rgba(239, 108, 0, 0.24);
  }

  .quick-link {
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.8rem;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, var(--accent), var(--accent-strong));
    color: white;
    font-weight: 700;
    box-shadow: 0 14px 30px rgba(239, 108, 0, 0.24);
  }

  .button.ghost {
    color: var(--text);
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.7);
    box-shadow: none;
  }

  .button.compact {
    min-height: 2.4rem;
    padding: 0.55rem 0.9rem;
    font-size: 0.92rem;
  }

  .section-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background: var(--panel);
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .section-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18), transparent 35%);
  }

  .announcement-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding: 1rem 1.25rem;
    background:
      linear-gradient(135deg, rgba(185, 255, 227, 0.78), rgba(255, 249, 241, 0.78)),
      var(--panel);
  }

  .announcement-copy strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.08rem;
  }

  .announcement-copy p {
    margin: 0.35rem 0 0;
  }

  .announcement-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-grid,
  .two-column,
  .detail-hero {
    display: grid;
    gap: 1.2rem;
    margin-bottom: 1.2rem;
  }

  .hero-grid {
    grid-template-columns: 1.75fr 1fr;
  }

  .two-column,
  .detail-hero {
    grid-template-columns: 1.35fr 0.95fr;
  }

  .hero-card,
  .hero-aside,
  .content-block,
  .sidebar-block,
  .rank-card,
  .project-card,
  .comments-panel {
    padding: 1.45rem;
  }

  .hero-card h1,
  .detail-title {
    margin: 0.35rem 0 1rem;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    line-height: 0.95;
  }

  .hero-card p,
  .hero-aside p,
  .section-panel p,
  .site-footer p,
  li {
    line-height: 1.7;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.86rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 800;
  }

  .muted {
    color: var(--text-soft);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
  }

  .section-heading h2 {
    margin: 0.25rem 0 0;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .metric-card,
  .stack-item,
  .flow-step,
  .list-link {
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--panel-strong);
    padding: 1rem;
  }

  .metric-card strong {
    display: block;
    font-size: 1.7rem;
    margin-top: 0.25rem;
    font-family: var(--font-display);
  }

  .project-grid,
  .rank-list,
  .list-stack,
  .category-grid,
  .mini-feed {
    display: grid;
    gap: 1rem;
  }

  .project-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .category-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .category-card {
    cursor: pointer;
    text-align: left;
    color: inherit;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    background: var(--panel-strong);
    padding: 1rem;
    font: inherit;
  }

  .category-card h3 {
    margin: 0.8rem 0 0.45rem;
    font-size: 1.22rem;
  }

  .stat-line,
  .meta-pair,
  .search-caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .stat-line {
    margin-top: 0.85rem;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .hero-lead {
    max-width: 58ch;
  }

  .project-count {
    font-size: 0.92rem;
    color: var(--text-soft);
  }

  .project-card h3,
  .rank-card h3,
  .list-link h3 {
    margin: 0.6rem 0 0.45rem;
    font-size: 1.35rem;
  }

  .owner-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.9rem;
  }

  .owner-meta img {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 999px;
    border: 1px solid var(--line);
  }

  .owner-meta strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
  }

  .card-band {
    position: absolute;
    inset: auto 1.3rem 0.8rem auto;
    width: 6rem;
    height: 6rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(239, 108, 0, 0.24), transparent 65%);
    filter: blur(6px);
  }

  .card-top,
  .metric-strip,
  .rank-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .meta-line {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .pill.subtle,
  .tag {
    background: rgba(255, 255, 255, 0.72);
  }

  .highlight-note {
    padding-left: 0.9rem;
    border-left: 3px solid rgba(15, 157, 138, 0.34);
    color: var(--text);
  }

  .metric-strip {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .mini-metrics {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.85rem;
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .metric-strip > div {
    min-width: 0;
  }

  .metric-label {
    display: block;
    font-size: 0.82rem;
    color: var(--text-soft);
  }

  .card-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .search-row {
    display: grid;
    gap: 1rem;
    margin: 1rem 0 1.35rem;
  }

  .search-input {
    width: 100%;
    min-height: 3.3rem;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.82);
    font: inherit;
  }

  .filter-pills button {
    cursor: pointer;
    font: inherit;
    color: var(--text);
  }

  .filter-pills button[data-active='true'] {
    background: linear-gradient(135deg, rgba(245, 127, 23, 0.18), rgba(15, 157, 138, 0.14));
    border-color: rgba(239, 108, 0, 0.24);
  }

  .list-stack {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .mini-feed-item strong {
    font-family: var(--font-display);
    font-size: 1.1rem;
  }

  .stack-item strong,
  .rank-number {
    font-family: var(--font-display);
    font-size: 1.6rem;
  }

  .rank-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .rank-number {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(239, 108, 0, 0.18), rgba(15, 157, 138, 0.18));
  }

  .notice {
    border-radius: var(--radius-lg);
    border: 1px dashed rgba(239, 108, 0, 0.28);
    background: rgba(255, 255, 255, 0.7);
    padding: 1rem;
  }

  .empty-state {
    padding: 2rem;
    text-align: center;
  }

  .owner-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .owner-row img {
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 999px;
    border: 1px solid var(--line);
  }

  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(52, 37, 17, 0.08);
    background: rgba(255, 249, 241, 0.68);
    backdrop-filter: blur(18px);
  }

  .footer-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    color: var(--text-soft);
  }

  @media (max-width: 960px) {
    .hero-grid,
    .two-column,
    .detail-hero,
    .project-grid,
    .category-grid {
      grid-template-columns: 1fr;
    }

    .header-shell,
    .footer-shell {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-subnav {
      flex-direction: column;
      align-items: flex-start;
    }

    .header-nav {
      width: 100%;
      overflow: auto;
      padding-bottom: 0.2rem;
    }

    .header-search {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    main {
      padding-top: 1rem;
    }

    .shell {
      width: min(calc(100% - 1rem), var(--max-width));
    }

    .hero-card,
    .hero-aside,
    .content-block,
    .sidebar-block,
    .rank-card,
    .project-card,
    .comments-panel {
      padding: 1.1rem;
    }

    .metric-grid {
      grid-template-columns: 1fr;
    }

    .announcement-strip {
      padding: 1rem;
    }
  }
</style>
