---
import Layout from '../layouts/Layout.astro';
import {
  activeProjects,
  breakoutProjects,
  buildTrendState,
  discoveryProjects,
  formatCompactNumber,
  formatDate,
  formatMomentum,
  formatPercentage,
  lastSyncedAt,
  projects,
  relativeDays,
  scaleLeaderProjects,
  totalStars,
  trendingProjects,
} from '../lib/projects';
import { baseUrl } from '../lib/site';
---

<Layout
  title="熱度榜 | Open Forum"
  description="用 stars、近期增量與更新活躍度組成的 GitHub 專案熱度榜。"
  current="rankings"
>
  <section class="shell section-panel content-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Trend Ranking</p>
        <h2>熱度榜</h2>
      </div>
    </div>

    <div class="notice">
      <p>
        趨勢分數會綜合 `stars`、`forks`、最近 1 天與 7 天的增星、以及最近一次 push 的新鮮度。
        這樣做的好處是，不會只讓老牌超大 repo 永遠霸榜，也能把近期變熱的專案抓出來。
      </p>
      <p class="muted">
        如果某個 repo 顯示「剛開始追蹤」，代表這是剛納入站內觀察名單，等歷史快照累積幾天後就會看到明確增量。
      </p>
    </div>

    <div class="metric-grid" style="margin-top: 1.2rem;">
      <div class="metric-card">
        <span class="metric-label">追蹤專案</span>
        <strong>{projects.length}</strong>
      </div>
      <div class="metric-card">
        <span class="metric-label">近 30 天活躍</span>
        <strong>{activeProjects}</strong>
      </div>
      <div class="metric-card">
        <span class="metric-label">總 stars</span>
        <strong>{formatCompactNumber(totalStars)}</strong>
      </div>
      <div class="metric-card">
        <span class="metric-label">最近同步</span>
        <strong>{formatDate(lastSyncedAt)}</strong>
      </div>
    </div>
  </section>

  <section class="shell section-panel content-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Ranking Angles</p>
        <h2>不要只看總星數，拆成幾種值得看的榜</h2>
      </div>
    </div>

    <div class="insight-grid">
      <div class="insight-card">
        <div class="meta-pair">
          <p class="eyebrow">7d 增量</p>
          <span class="pill">Top Movers</span>
        </div>
        <div class="list-stack">
          {trendingProjects.slice(0, 4).map((project, index) => (
            <a class="list-link compact-link" href={`${baseUrl}projects/${project.slug}/`}>
              <div class="rank-meta">
                <span class="rank-number">{String(index + 1).padStart(2, '0')}</span>
                <span>{formatMomentum(project)}</span>
              </div>
              <h3>{project.fullName}</h3>
              <p class="muted">{project.highlight}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="insight-card">
        <div class="meta-pair">
          <p class="eyebrow">相對增幅</p>
          <span class="pill">Breakout</span>
        </div>
        <div class="list-stack">
          {breakoutProjects.slice(0, 4).map((project, index) => (
            <a class="list-link compact-link" href={`${baseUrl}projects/${project.slug}/`}>
              <div class="rank-meta">
                <span class="rank-number">{String(index + 1).padStart(2, '0')}</span>
                <span>{project.historyDays < 7 ? '觀察中' : `7d ${formatPercentage(project.growthRate7d)}`}</span>
              </div>
              <h3>{project.fullName}</h3>
              <p class="muted">
                {project.historyDays < 7
                  ? '剛開始累積歷史資料，先觀察幾天。'
                  : `相對於一週前，已成長 ${formatPercentage(project.growthRate7d)}。`}
              </p>
            </a>
          ))}
        </div>
      </div>

      <div class="insight-card">
        <div class="meta-pair">
          <p class="eyebrow">值得挖掘</p>
          <span class="pill">Discovery</span>
        </div>
        <div class="list-stack">
          {discoveryProjects.slice(0, 4).map((project, index) => (
            <a class="list-link compact-link" href={`${baseUrl}projects/${project.slug}/`}>
              <div class="rank-meta">
                <span class="rank-number">{String(index + 1).padStart(2, '0')}</span>
                <span>{buildTrendState(project).label}</span>
              </div>
              <h3>{project.fullName}</h3>
              <p class="muted">{buildTrendState(project).description}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="shell section-panel content-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Scale Leaders</p>
        <h2>大盤代表</h2>
      </div>
    </div>

    <div class="list-stack">
      {scaleLeaderProjects.slice(0, 3).map((project, index) => (
        <a class="list-link compact-link" href={`${baseUrl}projects/${project.slug}/`}>
          <div class="rank-meta">
            <span class="rank-number">{String(index + 1).padStart(2, '0')}</span>
            <span>{formatCompactNumber(project.stars)} stars</span>
          </div>
          <h3>{project.fullName}</h3>
          <p class="muted">{project.highlight}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="shell section-panel content-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Master Ranking</p>
        <h2>完整熱度排序</h2>
      </div>
    </div>

    {
      projects.length ? (
        <div class="rank-list" style="margin-top: 1.2rem;">
          {projects.map((project, index) => (
            <article class="rank-card section-panel">
              <div class="rank-number">{String(index + 1).padStart(2, '0')}</div>
              <div>
                <div class="rank-meta">
                  <span class="pill">{project.category}</span>
                  {project.language && <span class="pill subtle">{project.language}</span>}
                  <span class:list={['trend-badge', `trend-${buildTrendState(project).tone}`]}>
                    {buildTrendState(project).label}
                  </span>
                </div>
                <h3>{project.fullName}</h3>
                <p class="muted">{project.description}</p>
                <p class="data-kicker">{buildTrendState(project).description}</p>
                <div class="rank-meta">
                  <span>{formatCompactNumber(project.stars)} stars</span>
                  <span>{formatMomentum(project)}</span>
                  <span>30d +{formatCompactNumber(project.delta30d)}</span>
                  <span>{project.historyDays} 天樣本</span>
                  <span>{project.historyDays < 7 ? '相對增幅累積中' : `7d 成長 ${formatPercentage(project.growthRate7d)}`}</span>
                  <span>趨勢分數 {formatCompactNumber(project.trendScore)}</span>
                  <span>{relativeDays(project.lastPushedAt)}</span>
                  <span>同步於 {formatDate(project.syncedAt)}</span>
                </div>
              </div>
              <div class="card-actions">
                <a class="button" href={`${baseUrl}projects/${project.slug}/`}>詳情</a>
                <a class="button ghost" href={project.repoUrl} target="_blank" rel="noreferrer">GitHub</a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>目前還沒有榜單資料。先執行 `npm run sync:data`。</p>
        </div>
      )
    }
  </section>
</Layout>
